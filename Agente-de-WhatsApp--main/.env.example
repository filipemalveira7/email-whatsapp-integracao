# whatsapp-zappfy-grupos — variáveis de ambiente
#
# Copie este arquivo pra `.env` e preencha. NÃO versione o .env (já no .gitignore).

# ─── Zappfy ───────────────────────────────────────────────────────
ZAPPFY_TOKEN=cole-aqui-o-uuid-da-sua-instancia
TEST_NUMBER=5511999998888       # seu WhatsApp pessoal com DDI (sem + ou espaço)
API_BASE=https://api.zappfy.io
# OPERATOR_NUMBER=5511999998888 # default: igual TEST_NUMBER (pra detectar role admin/membro)

# ─── Inbox ────────────────────────────────────────────────────────
# Endpoint da Zappfy pra puxar mensagens recebidas. Default: /chat/messages
# Se sua versão da Zappfy não tem, configure /messages/list ou use webhook
ENDPOINT_INBOX=/chat/messages

# Webhook — token opcional pra autenticar requisições do painel Zappfy
WEBHOOK_TOKEN=

# Auto-replies (override se quiser personalizar)
AUTO_REPLY_OPT_OUT=ok, parei. Você não vai mais receber mensagens nossas.
AUTO_REPLY_AGENDAMENTO=Boa! Agenda direto pelo link 👇\n{calendly}\n\nAssim sai certinho no horário que cabe pra você.
AUTO_REPLY_SAUDACAO=oi! tudo bem? Sou da [SUA EMPRESA]. Como posso te ajudar?

# ─── Calendly / Cal.com ───────────────────────────────────────────
# Quando lead responde com intenção de agendamento, o agente envia este link
CALENDLY_URL=https://calendly.com/seu-usuario/30min

# ─── Qualificação BANT (override pras 3 perguntas) ────────────────
QUALIFY_Q1=Oi {{first_name}}! Pergunta rápida pra entender se faz sentido — qual seu maior desafio hoje?
QUALIFY_Q2=E nessa decisão, você é quem decide ou tem alguém junto?
QUALIFY_Q3=Qual seu prazo pra resolver isso? (essa semana / esse mês / esse trimestre / sem pressa)
QUALIFY_DELAY_BETWEEN_Q=60

# ─── Followup ─────────────────────────────────────────────────────
FOLLOWUP_DELAY=75

# ─── Pipeline / Forecast ──────────────────────────────────────────
DEFAULT_TICKET=1000

# ─── Outlook watch (notifica novo e-mail no WhatsApp) ──────────────
# App registrado no Azure AD (App registrations), permissão delegada Mail.Read,
# "Allow public client flows" = Yes. Ver COMO-INSTALAR.md pro passo a passo.
MS_CLIENT_ID=
MS_TENANT_ID=
# Número que recebe a notificação. Default: OPERATOR_NUMBER, depois TEST_NUMBER
OUTLOOK_NOTIFY_NUMBER=
